---
title: "Memory Palace â€” System Architecture"
---
flowchart TB
    subgraph HUMAN["đź‘¤ Human Operator"]
        direction LR
        H_SOURCE["Drop raw source\n(article, paper, transcript)"]
        H_QUERY["Ask question\nor give command"]
        H_BROWSE["Browse wiki\nin Obsidian"]
        H_FEEDBACK["Approve / Reject\n(feedback loop)"]
    end

    subgraph RAW["đź“¦ Layer 0 â€” Raw Sources (Immutable)"]
        direction LR
        RAW_DIR["raw/\nâ”śâ”€ articles/\nâ”śâ”€ papers/\nâ”śâ”€ transcripts/\nâ”śâ”€ images/\nâ””â”€ data/"]
    end

    subgraph INGEST["âš™ď¸Ź Ingest Pipeline"]
        direction TB
        DETECT["Detect new / changed\nsource files"]
        EXTRACT["LLM: Extract entities,\nclaims, relationships"]
        DEDUP["De-duplicate entities\n(alias resolution)"]
        CONTRADICT["Detect contradictions\nwith existing claims"]
        SUPERSEDE["Supersede stale claims\n(temporal ordering)"]
        RECOMPILE["Regenerate L0 cache\n+ affected L1 clusters"]
        LOG_INGEST["Append to ingest_log"]

        DETECT --> EXTRACT --> DEDUP --> CONTRADICT --> SUPERSEDE --> RECOMPILE --> LOG_INGEST
    end

    subgraph STORE["đź—„ď¸Ź Layer 1 â€” Structured Store (Source of Truth)"]
        direction TB
        SQLITE[("SQLite\n+ FTS5 index")]
        subgraph TABLES["Tables"]
            direction LR
            T_SRC["source"]
            T_ENT["entity"]
            T_CLM["claim"]
            T_REL["relationship"]
            T_TOP["topic_cluster"]
            T_CON["contradiction"]
            T_LOG["ingest_log"]
        end
        CACHE[("projection_cache\n(L0 / L1 / L2)")]
        SQLITE --- TABLES
        SQLITE --- CACHE
    end

    subgraph PROJECT["đź”® Layer 2 â€” Projection Engine"]
        direction TB
        ROUTER{"Query Router"}
        L0_READ["Read L0 global summary\n(always cached, ~2K tokens)"]
        FTS["FTS5 keyword search"]
        GRAPH["Graph traversal\n(entity â†’ claims â†’ relationships)"]
        ASSEMBLE["Assemble context document\n(L0 + relevant L1 + optional L2)"]
        TOKEN_BUDGET["Trim to token budget\n(priority Ă— recency Ă— confidence)"]

        ROUTER --> L0_READ
        ROUTER --> FTS
        ROUTER --> GRAPH
        L0_READ --> ASSEMBLE
        FTS --> ASSEMBLE
        GRAPH --> ASSEMBLE
        ASSEMBLE --> TOKEN_BUDGET
    end

    subgraph LLM_LAYER["đź§  LLM Reasoning"]
        CONTEXT["Injected context\n(system prompt + projected memory)"]
        REASON["LLM generates answer"]
        FILE_BACK{"Worth keeping?"}
        NEW_CLAIM["Write answer back\nas new claims"]

        CONTEXT --> REASON --> FILE_BACK
        FILE_BACK -- "yes" --> NEW_CLAIM
        FILE_BACK -- "no" --> RESPOND
    end

    subgraph EXPORT["đź“„ Layer 3 â€” Presentation (Read-Only)"]
        direction TB
        MAKE_WIKI["make wiki\n(scheduled or on-demand)"]
        WIKI_DIR["wiki/\nâ”śâ”€ index.md\nâ”śâ”€ entities/\nâ”‚   â”śâ”€ person_*.md\nâ”‚   â””â”€ concept_*.md\nâ”śâ”€ topics/\nâ”śâ”€ contradictions.md\nâ”śâ”€ timeline.md\nâ””â”€ graph_report.md"]
        OBSIDIAN["Obsidian\n(graph view, Dataview,\nbrowse + read only)"]

        MAKE_WIKI --> WIKI_DIR --> OBSIDIAN
    end

    subgraph MAINT["đź”§ Maintenance (Cron)"]
        direction LR
        LINT["Lint:\norphans, contradictions,\nstale claims, missing entities"]
        PRUNE["Prune:\nexpire tactical claims\n(TTL-based)"]
        REINDEX["Reindex:\nrebuild FTS5,\nregenerate L0/L1 caches"]
        HEALTH["Health check:\nreport to health.md"]

        LINT ~~~ PRUNE ~~~ REINDEX ~~~ HEALTH
    end

    RESPOND(["đź’¬ Response to user"])

    %% â”€â”€ Flows â”€â”€

    H_SOURCE --> RAW_DIR
    RAW_DIR --> DETECT
    LOG_INGEST --> SQLITE
    SUPERSEDE --> SQLITE
    RECOMPILE --> CACHE

    H_QUERY --> ROUTER
    TOKEN_BUDGET --> CONTEXT
    NEW_CLAIM --> SQLITE

    SQLITE --> MAKE_WIKI
    SQLITE --> FTS
    SQLITE --> GRAPH
    CACHE --> L0_READ

    H_BROWSE --> OBSIDIAN
    H_FEEDBACK --> SQLITE

    MAINT --> SQLITE

